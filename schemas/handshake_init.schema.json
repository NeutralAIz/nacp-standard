{
  "$id": "https://nacp.dev/schemas/handshake_init.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Handshake Init Payload",
  "description": "Payload for HANDSHAKE_INIT messages.",
  "type": "object",
  "properties": {
    "ed25519_public_key": {
      "type": "string",
      "description": "Base64 Ed25519 public key for identity"
    },
    "x25519_ephemeral_public": {
      "type": "string",
      "description": "Base64 X25519 ephemeral public key for key exchange"
    },
    "supported_ciphers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "xsalsa20-poly1305"
      ]
    },
    "session_purpose": {
      "type": "string",
      "description": "Purpose of the encrypted session"
    }
  },
  "required": [
    "ed25519_public_key",
    "x25519_ephemeral_public"
  ],
  "additionalProperties": true
}
